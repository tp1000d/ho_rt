# Generated artifacts (large, regenerable)
*.sif
*.sif.bak
horp.sif
*.sif.tmp

# Singularity / Apptainer caches built next to the def
.singularity.d/
sandbox/
.apptainer/

# SLURM logs & per-job outputs
logs/
*.out
*.err
*.log

# Python build leftovers
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# Datasets (populated at runtime by sbatch jobs; large)
data/tfrecords/*.tfrecords
data/traced_paths/*.tfrecords
data/traced_paths/*.json
*.parts/

# Trained weights (regenerable, large)
checkpoints/*.h5
checkpoints/*.npz
checkpoints/*.weights.h5
checkpoints/*.pkl
checkpoints/itu_materials/
checkpoints/learned_materials/
checkpoints/neural_materials/

# Tensorboard logs from training notebooks
tb_logs/

# Notebook execution side effects
*.ipynb_checkpoints
notebooks/*.html
notebooks/*.executed.ipynb

# Run-time training output artifacts
results/synthetic/*.pdf
results/measurements/*.pdf
results/**/train_dict.pkl
results/**/*.pkl
results/**/*.npz

# Editor / OS noise
.DS_Store
.vscode/
.idea/
*.swp
*~
*.pdf

# Per-job DrJit cache homes (created at runtime to work around
# host $HOME being read-only inside singularity on torch)
.drjit_home_*/
