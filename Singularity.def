Bootstrap: docker
From: nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

# Singularity image for "Learning Radio Environments by Differentiable Ray Tracing"
# (Hoydis et al., 2023) on NYU torch HPC H200 nodes.
#
# Built once on a CPU node:
#   sbatch slurm/build_singularity.sbatch
#
# Image plus a writable overlay (so we can pip install at runtime if needed)
# produces a fully reproducible env: TF 2.15, Sionna 0.18, drjit 1.3.1,
# mitsuba 3.8.0 + the patches in compat/.

%files
    compat/_drjit1x_compat.py /opt/compat/_drjit1x_compat.py
    compat/apply_sionna_patches.py /opt/compat/apply_sionna_patches.py

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        python3.10 python3.10-venv python3-pip \
        ca-certificates curl git build-essential \
        libgl1 libglib2.0-0
    rm -rf /var/lib/apt/lists/*

    # Use python3.10 as default
    update-alternatives --install /usr/bin/python python /usr/bin/python3.10 1
    update-alternatives --install /usr/bin/pip pip /usr/bin/pip3 1

    python -m pip install --upgrade pip

    # TensorFlow 2.15 with bundled CUDA libs (works on H200, sm_90 backwards compat).
    pip install --no-cache-dir "tensorflow[and-cuda]==2.15.1"

    # Sionna 0.18 + DrJit 1.x stack (newer OptiX 8 ABI matches recent drivers).
    pip install --no-cache-dir \
        "sionna==0.18.0" \
        "drjit==1.3.1" \
        "mitsuba==3.8.0" \
        jupyter matplotlib pandas scipy

    # Apply the Sionna 0.18 <-> drjit 1.x compat patches in-place.
    python /opt/compat/apply_sionna_patches.py

    # Sanity check: import everything and confirm cuda variant resolves.
    python - <<'PY'
import tensorflow as tf, sionna, sionna.rt, mitsuba as mi, drjit as dr
print("TF:", tf.__version__, "Sionna:", sionna.__version__,
      "Mitsuba:", mi.__version__, "DrJit:", dr.__version__)
PY

%environment
    export TF_CPP_MIN_LOG_LEVEL=3
    export PYTHONNOUSERSITE=1

%runscript
    exec python "$@"

%labels
    Author Auto-built for tp1000d/ho_rt
    Description Sionna 0.18 + drjit 1.x compat + diff-rt-calibration patches
